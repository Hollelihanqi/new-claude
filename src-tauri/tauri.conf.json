{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Route Manager",
  "version": "1.0.0",
  "identifier": "com.ccswitch.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Code 配置工具",
        "width": 980,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Hollelihanqi/new-claude/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg4RkMxRTFBRkJDNEQ5MjEKUldRaDJjVDdHaDc4aU8razlEMDU4R1J0UHNYd3RwQTVMOHZZaGdoZCtDWGFQck5sOVROMEtPcDgK"
    }
  }
}
